{
  "schema_version": "2.1.0",
  "package_id": "qa_fixture_good",
  "primary_architecture": "single_period_full",
  "bundle": {
    "bundle_id": "qa_fixture_good_bundle",
    "declared_outputs": [
      "teacher_guide",
      "slides",
      "worksheet",
      "exit_ticket"
    ]
  },
  "teacher_guide": {
    "big_idea": "Keep outputs separated by audience while preserving final evidence location."
  },
  "slides": [
    {
      "title": "Kickoff",
      "layout": "prompt",
      "content": {
        "scenario": "Read and discuss.",
        "prompts": ["Notice", "Wonder"]
      }
    }
  ],
  "worksheet": {
    "questions": [
      { "q_num": 1, "q_text": "Show your thinking.", "n_lines": 3 }
    ]
  },
  "exit_ticket": {
    "prompt": "Final response",
    "n_lines": 3
  },
  "outputs": [
    {
      "output_id": "teacher_main",
      "output_type": "teacher_guide",
      "audience": "teacher",
      "source_section": "teacher_guide",
      "bundle": "qa_fixture_good_bundle"
    },
    {
      "output_id": "slides_main",
      "output_type": "slides",
      "audience": "shared_view",
      "source_section": "slides",
      "bundle": "qa_fixture_good_bundle"
    },
    {
      "output_id": "worksheet_main",
      "output_type": "worksheet",
      "audience": "student",
      "source_section": "worksheet",
      "bundle": "qa_fixture_good_bundle"
    },
    {
      "output_id": "exit_ticket_main",
      "output_type": "exit_ticket",
      "audience": "student",
      "source_section": "exit_ticket",
      "bundle": "qa_fixture_good_bundle",
      "final_evidence": true
    }
  ]
}
