{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mr-friess-classroom-engine/schemas/classroom-activity.schema.json",
  "title": "Classroom Activity Schema",
  "type": "object",
  "required": [
    "type",
    "activity_id",
    "activity_family",
    "activity_subtype",
    "title",
    "skill_focus",
    "grade_band",
    "subject",
    "time_minutes",
    "delivery_tags",
    "use_cases",
    "difficulty_tier",
    "support_level",
    "thinking_level",
    "materials",
    "setup",
    "teacher_script",
    "student_directions",
    "round_structure",
    "response_set",
    "content_bank",
    "variations",
    "answer_key",
    "render_hints",
    "outputs"
  ],
  "properties": {
    "type": { "type": "string", "const": "classroom_activity" },
    "activity_id": { "type": "string", "minLength": 1 },
    "activity_family": { "type": "string", "minLength": 1 },
    "activity_subtype": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "skill_focus": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "grade_band": { "type": "string", "enum": ["K-2", "3-5", "6-8", "9-12"] },
    "subject": { "type": "string", "minLength": 1 },
    "time_minutes": { "type": "integer", "minimum": 1 },
    "delivery_tags": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/deliveryTag" } },
    "use_cases": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/useCase" } },
    "difficulty_tier": { "$ref": "#/$defs/difficultyTier" },
    "support_level": { "$ref": "#/$defs/supportLevel" },
    "thinking_level": { "$ref": "#/$defs/thinkingLevel" },
    "materials": { "type": "array", "items": { "type": "string" } },
    "setup": { "type": "object", "required": ["prep_level"], "properties": {
      "prep_level": { "type": "string", "enum": ["none", "low", "medium"] },
      "room_setup": { "type": "array", "items": { "type": "string" } },
      "grouping": { "type": "string" },
      "reset_notes": { "type": "array", "items": { "type": "string" } }
    }, "additionalProperties": true },
    "teacher_script": { "type": "object", "properties": {
      "launch": { "type": "array", "items": { "type": "string" } },
      "between_rounds": { "type": "array", "items": { "type": "string" } },
      "debrief": { "type": "array", "items": { "type": "string" } }
    }, "additionalProperties": true },
    "student_directions": { "type": "array", "items": { "type": "string" } },
    "round_structure": { "type": "object", "properties": {
      "round_count": { "type": "integer", "minimum": 1 },
      "round_sequence": { "type": "array", "items": { "$ref": "#/$defs/roundNode" } },
      "debrief_questions": { "type": "array", "items": { "type": "string" } }
    }, "additionalProperties": true },
    "response_set": { "type": "object", "required": ["mode", "options"], "properties": {
      "mode": { "type": "string", "enum": ["corners", "whiteboard", "station_card", "mixed"] },
      "options": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
    }, "additionalProperties": true },
    "content_bank": { "$ref": "#/$defs/contentBank" },
    "variations": { "type": "object", "properties": {
      "whiteboard": { "$ref": "#/$defs/variationBlock" },
      "easier": { "$ref": "#/$defs/variationBlock" },
      "harder": { "$ref": "#/$defs/variationBlock" },
      "station": { "$ref": "#/$defs/variationBlock" },
      "worksheet_companion": { "$ref": "#/$defs/variationBlock" }
    }, "additionalProperties": true },
    "extension_questions": { "type": "array", "items": { "type": "string" } },
    "exit_slip": { "type": "object", "properties": {
      "prompt": { "type": "string" },
      "response_lines": { "type": "integer", "minimum": 1 }
    }, "additionalProperties": true },
    "answer_key": { "type": "array", "items": { "type": "string" } },
    "teacher_notes": { "type": "array", "items": { "type": "string" } },
    "differentiation_notes": { "type": "array", "items": { "type": "string" } },
    "curricular_links": { "type": "array", "items": { "type": "string" } },
    "render_hints": { "type": "object", "properties": {
      "teacher_card_style": { "type": "string" },
      "student_surface_style": { "type": "string" },
      "compactness": { "type": "string", "enum": ["tight", "standard"] }
    }, "additionalProperties": true },
    "bank_index_tags": { "type": "array", "items": { "type": "string" } },
    "outputs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/output" } }
  },
  "$defs": {
    "deliveryTag": { "type": "string", "enum": ["movement", "game", "whiteboard", "station", "quick_practice", "early_finisher", "low_prep", "teacher_led", "small_group", "whole_class"] },
    "useCase": { "type": "string", "enum": ["activity_only", "lesson_extension", "intervention_station", "early_finisher", "worksheet_companion"] },
    "difficultyTier": { "type": "string", "enum": ["easiest", "easy", "core", "stretch"] },
    "supportLevel": { "type": "string", "enum": ["high_support", "medium_support", "low_support"] },
    "thinkingLevel": { "type": "string", "enum": ["recall", "understand", "apply", "analyze", "evaluate", "create"] },
    "promptType": { "type": "string", "enum": ["real_word_build", "word_meaning_match", "root_meaning_match", "mixed_word_part_build", "trap_round", "teacher_readaloud"] },
    "answerPattern": { "type": "string", "enum": ["single_correct", "multi_correct", "none_correct"] },
    "validationStatus": { "type": "string", "enum": ["draft", "verified"] },
    "bankItem": {
      "type": "object",
      "required": ["item_id", "prompt_type", "stem", "display_prompt", "response_options", "correct_responses", "answer_pattern", "trap_flag", "difficulty_tier", "support_level", "whiteboard_compatible", "movement_compatible", "explanation", "validation_status"],
      "properties": {
        "item_id": { "type": "string", "minLength": 1 },
        "prompt_type": { "$ref": "#/$defs/promptType" },
        "stem": { "type": "string", "minLength": 1 },
        "display_prompt": { "type": "string", "minLength": 1 },
        "response_options": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "correct_responses": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "answer_pattern": { "$ref": "#/$defs/answerPattern" },
        "trap_flag": { "type": "boolean" },
        "trap_type": { "type": "string" },
        "difficulty_tier": { "$ref": "#/$defs/difficultyTier" },
        "support_level": { "$ref": "#/$defs/supportLevel" },
        "whiteboard_compatible": { "type": "boolean" },
        "movement_compatible": { "type": "boolean" },
        "explanation": { "type": "string", "minLength": 1 },
        "teacher_note": { "type": "string" },
        "validation_status": { "$ref": "#/$defs/validationStatus" }
      },
      "additionalProperties": true
    },
    "contentBank": {
      "type": "object",
      "required": ["bank_id", "items"],
      "properties": {
        "bank_id": { "type": "string", "minLength": 1 },
        "selection_note": { "type": "string" },
        "items": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/bankItem" } }
      },
      "additionalProperties": true
    },
    "variationBlock": {
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "notes": { "type": "array", "items": { "type": "string" } },
        "prompt_adjustments": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "roundNode": {
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "prompt_type": { "$ref": "#/$defs/promptType" },
        "item_ids": { "type": "array", "items": { "type": "string" } },
        "teacher_move": { "type": "string" }
      },
      "additionalProperties": true
    },
    "output": {
      "type": "object",
      "required": ["output_id", "output_type", "audience", "source_section"],
      "properties": {
        "output_id": { "type": "string", "minLength": 1 },
        "output_type": { "type": "string", "enum": ["activity_card", "lesson_extension_block", "station_card", "early_finisher_card", "worksheet_companion"] },
        "audience": { "type": "string", "enum": ["teacher", "student", "shared_view"] },
        "source_section": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
