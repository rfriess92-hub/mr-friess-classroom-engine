{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mr-friess-classroom-engine/schemas/deployment-template.schema.json",
  "title": "Deployment Template Schema",
  "type": "object",
  "required": ["template_id", "title", "time_minutes", "phase_sequence", "win_condition", "teacher_note"],
  "properties": {
    "template_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "time_minutes": { "type": "integer", "minimum": 1 },
    "phase_sequence": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "win_condition": { "type": "string", "minLength": 1 },
    "teacher_note": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": true
}
