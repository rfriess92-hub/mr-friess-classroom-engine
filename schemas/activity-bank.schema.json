{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mr-friess-classroom-engine/schemas/activity-bank.schema.json",
  "title": "Activity Content Bank Schema",
  "type": "object",
  "required": ["type", "bank_id", "activity_family", "title", "subject", "grade_band", "index_axes", "items"],
  "properties": {
    "type": { "type": "string", "const": "activity_bank" },
    "bank_id": { "type": "string", "minLength": 1 },
    "activity_family": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "subject": { "type": "string", "minLength": 1 },
    "grade_band": { "type": "string", "enum": ["K-2", "3-5", "6-8", "9-12"] },
    "skill_focus": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "index_axes": {
      "type": "object",
      "properties": {
        "word_part_focus": { "type": "array", "items": { "type": "string", "enum": ["prefixes", "suffixes", "roots", "mixed"] } },
        "difficulty_ladder": { "type": "array", "items": { "type": "string", "enum": ["easiest", "easy", "core", "stretch"] } },
        "delivery_modes": { "type": "array", "items": { "type": "string", "enum": ["movement", "whiteboard", "station"] } },
        "time_bands": { "type": "array", "items": { "type": "string", "enum": ["5_min", "10_min", "15_min"] } },
        "support_bands": { "type": "array", "items": { "type": "string", "enum": ["high_support", "medium_support", "low_support"] } }
      },
      "additionalProperties": true
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["item_id", "prompt_type", "stem", "display_prompt", "response_options", "correct_responses", "answer_pattern", "trap_flag", "difficulty_tier", "support_level", "whiteboard_compatible", "movement_compatible", "explanation", "validation_status"],
        "properties": {
          "item_id": { "type": "string", "minLength": 1 },
          "prompt_type": { "type": "string", "enum": ["real_word_build", "word_meaning_match", "root_meaning_match", "mixed_word_part_build", "trap_round", "teacher_readaloud"] },
          "stem": { "type": "string", "minLength": 1 },
          "display_prompt": { "type": "string", "minLength": 1 },
          "response_options": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "correct_responses": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "answer_pattern": { "type": "string", "enum": ["single_correct", "multi_correct", "none_correct"] },
          "trap_flag": { "type": "boolean" },
          "trap_type": { "type": "string" },
          "difficulty_tier": { "type": "string", "enum": ["easiest", "easy", "core", "stretch"] },
          "support_level": { "type": "string", "enum": ["high_support", "medium_support", "low_support"] },
          "whiteboard_compatible": { "type": "boolean" },
          "movement_compatible": { "type": "boolean" },
          "explanation": { "type": "string", "minLength": 1 },
          "teacher_note": { "type": "string" },
          "validation_status": { "type": "string", "enum": ["draft", "verified"] }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
