{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mr-friess-classroom-engine/schemas/activity-bank.schema.json",
  "title": "Activity Bank Schema",
  "type": "object",
  "required": [
    "type",
    "bank_id",
    "bank_type",
    "strand",
    "theme",
    "difficulty",
    "transparency_level",
    "bank_purpose",
    "core_items",
    "core_meanings",
    "teacher_note_on_meaning",
    "starter_examples",
    "core_examples",
    "stretch_examples",
    "trap_bank",
    "teacher_note_on_traps",
    "best_fit_families",
    "acceptable_families",
    "use_carefully_families",
    "sentence_target_bank",
    "repair_target_bank",
    "sort_target_bank",
    "build_target_bank",
    "relay_target_bank",
    "starter_notes",
    "core_notes",
    "stretch_notes",
    "answer_key_language",
    "usage_notes",
    "qc"
  ],
  "properties": {
    "type": { "type": "string", "const": "activity_bank" },
    "bank_id": { "type": "string", "minLength": 1 },
    "bank_type": { "type": "string", "enum": ["prefix", "suffix", "root", "mixed", "foundational"] },
    "strand": { "type": "string", "enum": ["morphology_word_knowledge", "foundational_word_reading"] },
    "theme": { "type": "string", "minLength": 1 },
    "difficulty": { "type": "string", "enum": ["starter", "core", "stretch"] },
    "transparency_level": { "type": "string", "enum": ["high", "medium", "low"] },
    "bank_purpose": { "type": "string", "minLength": 1 },
    "core_items": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "core_meanings": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "teacher_note_on_meaning": { "type": "string", "minLength": 1 },
    "starter_examples": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/bankExample" } },
    "core_examples": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/bankExample" } },
    "stretch_examples": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/bankExample" } },
    "trap_bank": {
      "type": "object",
      "required": ["fake", "near_miss", "arguable"],
      "properties": {
        "fake": { "type": "array", "items": { "$ref": "#/$defs/trapExample" } },
        "near_miss": { "type": "array", "items": { "$ref": "#/$defs/trapExample" } },
        "arguable": { "type": "array", "items": { "$ref": "#/$defs/trapExample" } }
      },
      "additionalProperties": false
    },
    "teacher_note_on_traps": { "type": "string", "minLength": 1 },
    "best_fit_families": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "acceptable_families": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "use_carefully_families": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "sentence_target_bank": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "repair_target_bank": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "sort_target_bank": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "build_target_bank": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "relay_target_bank": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "starter_notes": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "core_notes": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "stretch_notes": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "answer_key_language": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "usage_notes": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "qc": {
      "type": "object",
      "required": ["gate_result", "rating_result", "final_bank_verdict"],
      "properties": {
        "gate_result": {
          "type": "object",
          "required": ["instructional_precision", "age_respect", "run_cold_reality", "game_worthiness", "content_depth"],
          "properties": {
            "instructional_precision": { "type": "boolean" },
            "age_respect": { "type": "boolean" },
            "run_cold_reality": { "type": "boolean" },
            "game_worthiness": { "type": "boolean" },
            "content_depth": { "type": "boolean" }
          },
          "additionalProperties": true
        },
        "rating_result": {
          "type": "object",
          "required": ["instructional_precision", "age_respect", "game_energy", "replay_value", "content_bank_depth", "implementation_reliability", "total"],
          "properties": {
            "instructional_precision": { "type": "integer", "minimum": 1, "maximum": 5 },
            "age_respect": { "type": "integer", "minimum": 1, "maximum": 5 },
            "game_energy": { "type": "integer", "minimum": 1, "maximum": 5 },
            "replay_value": { "type": "integer", "minimum": 1, "maximum": 5 },
            "content_bank_depth": { "type": "integer", "minimum": 1, "maximum": 5 },
            "implementation_reliability": { "type": "integer", "minimum": 1, "maximum": 5 },
            "total": { "type": "integer", "minimum": 6, "maximum": 30 }
          },
          "additionalProperties": true
        },
        "final_bank_verdict": { "type": "string", "enum": ["ready", "strong_needs_polish", "promising_not_stable", "rebuild"] }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "difficultyTag": { "type": "string", "enum": ["starter", "core", "stretch"] },
    "trapTag": { "type": "string", "enum": ["fake", "near_miss", "arguable"] },
    "bankExample": {
      "type": "object",
      "required": ["item_id", "difficulty_tag", "display_prompt", "response_options", "correct_responses", "answer_pattern", "explanation"],
      "properties": {
        "item_id": { "type": "string", "minLength": 1 },
        "difficulty_tag": { "$ref": "#/$defs/difficultyTag" },
        "display_prompt": { "type": "string", "minLength": 1 },
        "response_options": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "correct_responses": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "answer_pattern": { "type": "string", "enum": ["single_correct", "multi_correct", "none_correct"] },
        "explanation": { "type": "string", "minLength": 1 },
        "teacher_note": { "type": "string" }
      },
      "additionalProperties": true
    },
    "trapExample": {
      "type": "object",
      "required": ["item_id", "difficulty_tag", "trap_tag", "display_prompt", "response_options", "correct_responses", "answer_pattern", "explanation"],
      "properties": {
        "item_id": { "type": "string", "minLength": 1 },
        "difficulty_tag": { "$ref": "#/$defs/difficultyTag" },
        "trap_tag": { "$ref": "#/$defs/trapTag" },
        "display_prompt": { "type": "string", "minLength": 1 },
        "response_options": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "correct_responses": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "answer_pattern": { "type": "string", "enum": ["single_correct", "multi_correct", "none_correct"] },
        "explanation": { "type": "string", "minLength": 1 },
        "teacher_note": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
