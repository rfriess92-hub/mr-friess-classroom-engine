{
  "$schema_version": "1.0.0",
  "schema_id": "mr_friess_visual_tokens",
  "token_sets": {
    "baseline_default": {
      "color": {
        "ink_primary": "#1F355E",
        "ink_secondary": "#344054",
        "paper": "#FCFBF8",
        "panel": "#F3F0EA",
        "panel_alt": "#EEE8DD",
        "support": "#D98B3A",
        "reflection": "#6D9C95",
        "extension": "#6E6A9E",
        "success": "#7A8A5B",
        "line": "#C8C2B8"
      },
      "type": {
        "font_family": "Inter, Aptos, Arial, sans-serif",
        "title_size": 28,
        "subtitle_size": 18,
        "section_label_size": 12,
        "body_size": 12,
        "small_size": 10,
        "title_weight": 700,
        "section_weight": 600,
        "body_weight": 400,
        "line_height": 1.3
      },
      "space": {
        "xxs": 4,
        "xs": 8,
        "sm": 12,
        "md": 16,
        "lg": 24,
        "xl": 32,
        "xxl": 48
      },
      "radius": {
        "sharp": 2,
        "soft": 8,
        "round": 14,
        "pill": 999
      },
      "stroke": {
        "thin": 1,
        "medium": 1.5,
        "heavy": 2
      },
      "icon": {
        "style": "simple_line",
        "default_size": 14,
        "label_gap": 6
      }
    },
    "playful_light_default": {
      "extends": "baseline_default",
      "overrides": {
        "color": {
          "panel": "#F7F3EC",
          "panel_alt": "#F2ECE2"
        },
        "radius": {
          "soft": 10,
          "round": 18
        },
        "icon": {
          "default_size": 16
        }
      }
    }
  },
  "token_rules": [
    "use one sans serif family across the system",
    "use accent colors by role, not decoratively",
    "never allow more than 3 accent roles on one page",
    "main instructional regions should use paper/panel tones, not bright fills"
  ]
}
