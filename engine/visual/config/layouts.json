{
  "$schema_version": "1.0.0",
  "schema_id": "mr_friess_layout_templates",
  "page_roles": {
    "slide_deck": [
      "hero",
      "prompt",
      "model",
      "compare",
      "reflect"
    ],
    "worksheet": [
      "handout_page_1",
      "handout_page_2",
      "final_response"
    ]
  },
  "slide_layouts": {
    "S_HERO": {
      "page_roles": [
        "hero"
      ],
      "regions": [
        "hero_band",
        "title_stage",
        "subtitle_stage",
        "visual_field"
      ],
      "budgets": {
        "max_words": 25,
        "max_lines": 5,
        "max_bullets": 0,
        "max_prompts": 0,
        "body_font_min": 24
      },
      "rules": [
        "title_stage is dominant",
        "support text stays minimal",
        "no support cards by default",
        "slide should feel like a classroom poster, not a dashboard"
      ]
    },
    "S_PROMPT": {
      "page_roles": [
        "prompt"
      ],
      "regions": [
        "title_band",
        "prompt_stage",
        "prompt_list"
      ],
      "budgets": {
        "max_words": 40,
        "max_lines": 7,
        "max_bullets": 3,
        "max_prompts": 3,
        "body_font_min": 24
      },
      "rules": [
        "prompt_stage is dominant",
        "prompt_list is secondary",
        "do not use stacked mini-cards",
        "keep one dominant question or scenario"
      ]
    },
    "S_MODEL": {
      "page_roles": [
        "model"
      ],
      "regions": [
        "title_band",
        "model_stage",
        "support_strip"
      ],
      "budgets": {
        "max_words": 50,
        "max_lines": 7,
        "max_bullets": 2,
        "max_prompts": 2,
        "body_font_min": 24
      },
      "rules": [
        "model_stage is dominant",
        "show one example only",
        "support_strip remains visually secondary"
      ]
    },
    "S_COMPARE": {
      "page_roles": [
        "compare"
      ],
      "regions": [
        "title_band",
        "compare_left",
        "compare_right",
        "takeaway_strip"
      ],
      "budgets": {
        "max_words": 45,
        "max_lines": 7,
        "max_bullets": 2,
        "max_prompts": 1,
        "body_font_min": 24
      },
      "rules": [
        "only one compare pair per slide",
        "left and right panels form one compare unit",
        "no extra dashboard cards"
      ]
    },
    "S_REFLECT": {
      "page_roles": [
        "reflect"
      ],
      "regions": [
        "title_band",
        "reflection_stage",
        "optional_prompt"
      ],
      "budgets": {
        "max_words": 30,
        "max_lines": 5,
        "max_bullets": 2,
        "max_prompts": 2,
        "body_font_min": 24
      },
      "rules": [
        "reflection_stage is dominant",
        "use more whitespace than any other slide family",
        "no three-stack prompt ladders",
        "keep the slide open and breathable"
      ]
    }
  },
  "worksheet_layouts": {
    "task_sheet_page_1": {
      "page_roles": [
        "handout_page_1"
      ],
      "regions": [
        "page_header",
        "entry_panel",
        "section_stack"
      ],
      "rules": [
        "entry_panel appears before first section",
        "each section contains prompt plus writing field",
        "scaffold cues may appear inline or side-attached"
      ]
    },
    "task_sheet_page_2": {
      "page_roles": [
        "handout_page_2"
      ],
      "regions": [
        "page_header",
        "checkpoint_panel",
        "response_block",
        "two_column_tools"
      ],
      "rules": [
        "support_tools and success_check must not share identical fill treatment",
        "support_tools should feel more active",
        "success_check should feel calmer"
      ]
    },
    "final_response_page": {
      "page_roles": [
        "final_response"
      ],
      "regions": [
        "page_header",
        "draft_prep_row",
        "structure_cue",
        "final_draft_field",
        "final_review"
      ],
      "rules": [
        "draft_prep_row may use 2-3 compact support cards",
        "final_draft_field is visually dominant",
        "final_review stays quiet and low contrast"
      ]
    }
  },
  "sequence_rules": {
    "slide_deck": [
      "across a 5-slide lesson sequence at least 3 different layout ids must be used",
      "no more than 2 consecutive slides may share the same layout id",
      "prompt and reflect slides should be the sparsest text surfaces in the deck",
      "if a slide exceeds its family budget, reroute or split instead of shrinking"
    ],
    "worksheet": [
      "every page gets one warm entry or orientation region",
      "no page should look like a continuous slab of equally tinted boxes",
      "writing space must occupy more visual openness than support cues",
      "checklists may not become the darkest or most prominent element on the page"
    ]
  }
}
